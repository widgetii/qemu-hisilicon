diff --git a/hw/ssi/pl022.c b/hw/ssi/pl022.c
index 1dc0bcb..680038e 100644
--- a/hw/ssi/pl022.c
+++ b/hw/ssi/pl022.c
@@ -66,6 +66,9 @@ static void pl022_update(PL022State *s)
         s->is |= PL022_INT_RX;
     if (s->tx_fifo_len <= 4)
         s->is |= PL022_INT_TX;
+    /* Receive timeout: RX FIFO has data but TX is idle (transfer done) */
+    if (s->rx_fifo_len > 0 && s->tx_fifo_len == 0)
+        s->is |= PL022_INT_RT;
 
     qemu_set_irq(s->irq, (s->is & s->im) != 0);
 }
@@ -208,6 +211,9 @@ static void pl022_write(void *opaque, hwaddr offset,
             qemu_log_mask(LOG_UNIMP, "pl022: DMA not implemented\n");
         }
         break;
+    case 0x28: /* HiSilicon DMA TX threshold (vendor extension) */
+    case 0x2c: /* HiSilicon DMA RX threshold (vendor extension) */
+        break;
     default:
         qemu_log_mask(LOG_GUEST_ERROR,
                       "pl022_write: Bad offset %x\n", (int)offset);
